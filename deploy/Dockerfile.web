# APP=web-admin | web-customer
# docker build -f deploy/Dockerfile.web --build-arg APP=web-admin \
#   --build-arg NEXT_PUBLIC_API_URL=https://api.example.com/v1 -t point-web-admin .
FROM node:20-bookworm-slim AS build
ARG APP=web-admin
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_CUSTOMER_WEB_URL
ARG NEXT_PUBLIC_MARKETING_WEB_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_CUSTOMER_WEB_URL=$NEXT_PUBLIC_CUSTOMER_WEB_URL
ENV NEXT_PUBLIC_MARKETING_WEB_URL=$NEXT_PUBLIC_MARKETING_WEB_URL
COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
RUN npm ci \
  && rm -rf node_modules/@types/react node_modules/@types/react-dom \
  && npm install --no-save --ignore-scripts @types/react@18.3.12 @types/react-dom@18.3.1
RUN npm run build -w @point/${APP}

FROM node:20-bookworm-slim AS run
ARG APP=web-admin
WORKDIR /app
ENV NODE_ENV=production
ENV APP_NAME=${APP}
# Next.js standalone output: runtime doesn't need `next` binary
COPY --from=build /app/apps/${APP}/.next/standalone ./
COPY --from=build /app/apps/${APP}/.next/static ./apps/${APP}/.next/static
COPY --from=build /app/apps/${APP}/public ./apps/${APP}/public
COPY --from=build /app/apps/${APP}/package.json ./apps/${APP}/package.json
COPY package.json ./package.json
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
EXPOSE 3000
CMD ["sh", "-c", "node apps/$APP_NAME/server.js"]
