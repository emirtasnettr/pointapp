# APP=web-admin | web-customer
# docker build -f deploy/Dockerfile.web --build-arg APP=web-admin \
#   --build-arg NEXT_PUBLIC_API_URL=https://api.example.com/v1 -t point-web-admin .
FROM node:20-bookworm-slim AS build
ARG APP=web-admin
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_CUSTOMER_WEB_URL
ARG NEXT_PUBLIC_MARKETING_WEB_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_CUSTOMER_WEB_URL=$NEXT_PUBLIC_CUSTOMER_WEB_URL
ENV NEXT_PUBLIC_MARKETING_WEB_URL=$NEXT_PUBLIC_MARKETING_WEB_URL
COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
RUN npm ci
RUN npm run build -w @point/${APP}

FROM node:20-bookworm-slim AS run
ARG APP=web-admin
WORKDIR /app
ENV NODE_ENV=production
ENV APP_NAME=${APP}
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/apps/${APP}/.next ./apps/${APP}/.next
COPY --from=build /app/apps/${APP}/public ./apps/${APP}/public
COPY --from=build /app/apps/${APP}/package.json ./apps/${APP}/package.json
COPY --from=build /app/apps/${APP}/scripts ./apps/${APP}/scripts
COPY package.json ./package.json
EXPOSE 3000
CMD ["sh", "-c", "if [ \"$APP_NAME\" = web-customer ]; then export WEB_CUSTOMER_PORT=3000; else export WEB_ADMIN_PORT=3000; fi && npm run start -w @point/$APP_NAME"]
