# Point production — kopyalayın: cp deploy/env.example deploy/.env
# Güçlü şifreler üretin; bu dosyayı asla repoya commit etmeyin.

# --- Veritabanı (docker compose içi postgres) ---
POSTGRES_USER=point
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=point
DATABASE_URL=postgresql://point:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/point?schema=public

# --- API ---
PORT=5001
HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
NODE_ENV=production

# Dış dünyanın API kökü (https, /v1 öneki yok — uygulama /v1 ekler)
PUBLIC_API_ORIGIN=https://api.pointkurye.net.tr

# Virgülle ayrılmış tam origin listesi (kök + www tanıtım + müşteri paneli)
CORS_ORIGINS=https://pointkurye.net.tr,https://www.pointkurye.net.tr,https://app.pointkurye.net.tr

# Yerel dosya deposu (Docker volume ile kalıcı)
STORAGE_LOCAL_DIR=/app/storage/uploads

# SMS: canlıda 0 — gerçek OTP; geliştirme için 1
POINT_SMS_SIMULATION=0

# --- Domainler (Caddy TLS) ---
API_DOMAIN=api.pointkurye.net.tr
# Caddy: tanıtım + yönetim (köknokta ve www aynı site)
ADMIN_DOMAINS=pointkurye.net.tr,www.pointkurye.net.tr
# Canonical linkler (NEXT_PUBLIC_MARKETING_WEB_URL)
ADMIN_DOMAIN=www.pointkurye.net.tr
CUSTOMER_DOMAIN=app.pointkurye.net.tr
CADDY_EMAIL=admin@pointkurye.net.tr

# --- Next.js build-time (https + /v1 ile bitmeli) ---
NEXT_PUBLIC_API_URL=https://api.pointkurye.net.tr/v1
NEXT_PUBLIC_CUSTOMER_WEB_URL=https://app.pointkurye.net.tr
NEXT_PUBLIC_MARKETING_WEB_URL=https://www.pointkurye.net.tr
