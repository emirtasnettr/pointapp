# Point production — kopyalayın: cp deploy/env.example deploy/.env
# Güçlü şifreler üretin; bu dosyayı asla repoya commit etmeyin.

# --- Veritabanı (docker compose içi postgres) ---
POSTGRES_USER=point
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=point
DATABASE_URL=postgresql://point:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/point?schema=public

# --- API ---
PORT=5001
HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
NODE_ENV=production

# Dış dünyanın API kökü (https, /v1 öneki yok — uygulama /v1 ekler)
PUBLIC_API_ORIGIN=https://api.ornek.com

# Virgülle ayrılmış tam origin listesi (web panelleri)
CORS_ORIGINS=https://panel.ornek.com,https://app.ornek.com

# Yerel dosya deposu (Docker volume ile kalıcı)
STORAGE_LOCAL_DIR=/app/storage/uploads

# SMS: canlıda 0 — gerçek OTP; geliştirme için 1
POINT_SMS_SIMULATION=0

# İsteğe bağlı
# EXPO_ACCESS_TOKEN=

# --- Domainler (Caddy TLS) ---
API_DOMAIN=api.ornek.com
ADMIN_DOMAIN=panel.ornek.com
CUSTOMER_DOMAIN=app.ornek.com
CADDY_EMAIL=admin@ornek.com

# --- Next.js build-time (https + /v1 ile bitmeli) ---
NEXT_PUBLIC_API_URL=https://api.ornek.com/v1
NEXT_PUBLIC_CUSTOMER_WEB_URL=https://app.ornek.com
NEXT_PUBLIC_MARKETING_WEB_URL=https://panel.ornek.com
