# Ortam değişkenleri deploy/.env içinden docker compose ile enjekte edilir.
# ADMIN_DOMAINS: virgülle ayrılmış tanıtım+yönetim hostları (köknokta + www)

{
	email {$CADDY_EMAIL}
}

{$API_DOMAIN} {
	encode gzip
	reverse_proxy api:5001
}

{$ADMIN_DOMAINS} {
	encode gzip
	reverse_proxy web-admin:3000
}

{$CUSTOMER_DOMAIN} {
	encode gzip
	reverse_proxy web-customer:3000
}
