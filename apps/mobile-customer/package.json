{
  "name": "@point/mobile-customer",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "prestart": "node scripts/free-metro-port.mjs",
    "start": "expo start --go --port 8081 --host lan",
    "start:clear": "expo start --go --port 8081 --host lan -c",
    "start:dev-client": "expo start --dev-client --host lan",
    "start:tunnel": "expo start --go --tunnel --port 8081",
    "android": "expo start --go --android",
    "ios": "expo start --go --ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "8.4.4",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-sharing": "~14.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
