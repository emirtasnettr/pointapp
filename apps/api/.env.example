DATABASE_URL="postgresql://point:point@localhost:5432/point?schema=public"
PORT=5001
JWT_SECRET=point-dev-jwt-change-me-local-only
# Logo / dosya URL’leri için API’nin dışarıdan erişilen kökü (web-admin önizleme ve system_settings).
# PUBLIC_API_ORIGIN=http://localhost:5001
# Yerel dosya deposu (varsayılan: <api cwd>/storage/uploads)
# STORAGE_LOCAL_DIR=
# CORS_ORIGINS boş bırakılırsa lokal geliştirmede tüm origin’lere izin verilir.

# Müşteri kaydı SMS simülasyonu: yanıtta düz OTP (prod’da mutlaka 0).
POINT_SMS_SIMULATION=1
